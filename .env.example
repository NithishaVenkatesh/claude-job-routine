# Copy to .env and fill in. The system RUNS without these (shadow mode); they unlock
# scoring refinement, email drafting, and sending.

# --- LLM: Azure OpenAI (primary provider) — unlocks Claude-grade scoring + email drafting ---
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>   # e.g. gpt-4o
# AZURE_OPENAI_API_VERSION=2024-06-01

# --- LLM: Anthropic (alternative; used only if Azure vars are absent) ---
# ANTHROPIC_API_KEY=
# JOBHUNTER_MODEL=claude-sonnet-5

# --- Contact discovery fallback (Apollo pool lives in secrets/apollo_accounts.yaml) ---
# (Hunter key also goes in secrets/apollo_accounts.yaml under fallback:)

# --- Optional job-source breadth / real web research ---
# SERPAPI_KEY=

# --- Email sending (simplest: Gmail App Password via SMTP) ---
# Requires 2-Step Verification ON for the sender account, then generate an App Password.
# GMAIL_SENDER=nithisha.codes@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx   # 16-char app password, no spaces

# Reporting sink (optional)
# SLACK_WEBHOOK_URL=
